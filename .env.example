# =============================================================
# AGENT OPTIMIZER - LOCAL DEVELOPMENT ENVIRONMENT
# These values MUST match the docker compose services.
# If they don't match, the app can't connect to Postgres
# =============================================================

# APPLICATION
NODE_ENV=development
API_PORT=3000

# API
API_PREFIX=api
API_VERSION=v1

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGINS=http://localhost:5173

# DB
DATABASE_URL="postgresql://optimizer:optimizer_dev@localhost:5432/agent_optimizer?schema=public"

# GHL sandbox env keys
LOCATION_ID=
ACCOUNT_PIT=
LOCATION_PIT=
AGENT_ID=