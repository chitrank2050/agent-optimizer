# =============================================================
# AGENT OPTIMIZER - LOCAL DEVELOPMENT ENVIRONMENT
# These values MUST match the docker compose services.
# If they don't match, the app can't connect to Postgres
# =============================================================

# APPLICATION
NODE_ENV=development
API_PORT=3000

# API
API_PREFIX=api
API_VERSION=v1

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGINS=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# DB
DATABASE_URL="postgresql://optimizer:optimizer_dev@localhost:55432/agent_optimizer?schema=public"
POSTGRES_USER=optimizer
POSTGRES_PASSWORD=optimizer_dev
POSTGRES_DB=agent_optimizer

# GHL sandbox env keys
GHL_LOCATION_ID=
GHL_ACCOUNT_PIT=
GHL_LOCATION_PIT=
GHL_AGENT_ID=
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
