{
  "name": "@agent-optimizer/api",
  "version": "0.1.0",
  "private": false,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint .",
    "test": "NODE_ENV=test DATABASE_URL=postgresql://optimizer:optimizer_dev@localhost:55432/agent_optimizer?schema=public vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@agent-optimizer/ai": "workspace:*",
    "@agent-optimizer/contracts": "workspace:*",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.1.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.13",
    "nest-winston": "^1.10.2",
    "winston": "^3.19.0",
    "compression": "^1.8.1",
    "@scalar/nestjs-api-reference": "^1.1.10"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.8",
    "@types/express": "^5.0.3",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "@types/compression": "^1.8.1"
  }
}
