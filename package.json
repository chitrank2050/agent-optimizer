{
  "name": "agent-optimizer",
  "private": true,
  "version": "0.1.0",
  "description": "HighLevel Voice AI Agent Optimizer monorepo.",
  "author": {
    "name": "Chitrank Agnihotri",
    "email": "chitrank2050@gmail.com",
    "url": "https://www.chitrankagnihotri.com"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/chitrank2050/agent-optimizer"
  },
  "bugs": {
    "url": "https://github.com/chitrank2050/agent-optimizer/issues"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "voice-agent",
    "high-level",
    "lead-agent",
    "marketing",
    "automation",
    "agent-optimizer"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,vue,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,json,md,yml,yaml,css}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:generate": "pnpm --filter @agent-optimizer/api db:generate",
    "// --- ⚙️ Maintenance ---": "",
    "setup": "pnpm install && pnpm db:generate && pnpm --filter @agent-optimizer/api db:migrate:deploy",
    "db:reset:dev": "pnpm --filter @agent-optimizer/api exec prisma migrate reset --schema prisma/schema.prisma",
    "deps:update": "pnpm update --interactive --latest"
  },
  "devDependencies": {
    "@chitrank2050/git-hygiene": "^0.4.12",
    "@types/node": "^25.9.1",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "git-hygiene": {
    "ignoreBranches": [
      "main"
    ]
  }
}
