{
  "name": "agent-optimizer",
  "private": false,
  "type": "module",
  "version": "0.1.0",
  "description": "HighLevel Voice AI Agent Optimizer monorepo.",
  "author": {
    "name": "Chitrank Agnihotri",
    "email": "chitrank2050@gmail.com",
    "url": "https://www.chitrankagnihotri.com"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/chitrank2050/agent-optimizer"
  },
  "bugs": {
    "url": "https://github.com/chitrank2050/agent-optimizer/issues"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "voice-agent",
    "high-level",
    "lead-agent",
    "marketing",
    "automation",
    "agent-optimizer"
  ],
  "scripts": {
    "// --- 🚀 Core ---": "",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "// --- 🧹 Hygiene ---": "",
    "lint": "turbo run lint && pnpm run lint:md",
    "lint:md": "markdownlint \"**/*.md\" --fix --ignore node_modules --ignore CHANGELOG.md",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,json,md,yml,yaml,css}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,js,json,md,yml,yaml,css}\" --ignore-path .prettierignore",
    "check-types": "turbo run typecheck",
    "typecheck": "turbo run typecheck",
    "// --- 🧪 Testing ---": "",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "// --- 🗄️ Database ---": "",
    "db:generate": "pnpm --filter @agent-optimizer/api run db:generate",
    "db:migrate:dev": "pnpm --filter @agent-optimizer/api run db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @agent-optimizer/api run db:migrate:deploy",
    "db:reset": "pnpm --filter @agent-optimizer/api exec prisma migrate reset",
    "// --- 🏗️ Infrastructure ---": "",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "// --- 📘 Documentation ---": "",
    "docs:build": "mkdocs build --strict",
    "docs:serve": "mkdocs serve",
    "// --- ⚙️ Maintenance ---": "",
    "prepare": "lefthook install",
    "setup": "pnpm install && pnpm run db:generate && pnpm run db:migrate:deploy",
    "nuke": "rm -rf node_modules pnpm-lock.yaml && pnpm install",
    "deps:update": "pnpm update --interactive --latest"
  },
  "devDependencies": {
    "@chitrank2050/git-hygiene": "^0.4.12",
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.60.0",
    "@swc/core": "^1.15.40",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.9.1",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-vue": "^9.32.0",
    "lefthook": "^1.10.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.22.0",
    "unplugin-swc": "^1.5.9",
    "vue-eslint-parser": "^9.4.3"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "git-hygiene": {
    "ignoreBranches": [
      "main"
    ]
  }
}
